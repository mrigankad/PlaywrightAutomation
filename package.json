{
  "name": "@email-automation/core",
  "version": "1.0.0",
  "description": "Production-grade automation pipeline: Extract data from emails and search portals with extensible plugin architecture",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./plugins": {
      "import": {
        "types": "./dist/plugins/index.d.ts",
        "default": "./dist/plugins/index.mjs"
      },
      "require": {
        "types": "./dist/plugins/index.d.ts",
        "default": "./dist/plugins/index.js"
      }
    }
  },
  "bin": {
    "email-automation": "./dist/cli.js",
    "email-auto": "./dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "PLUGINS.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:clean": "rimraf dist && npm run build",
    "start": "ts-node src/cli.ts",
    "dev": "ts-node src/runner.ts",
    "run": "npm run build && node dist/runner.js",
    "cli": "ts-node src/cli.ts",
    "auth": "ts-node src/cli.ts --count 0",
    "quick": "ts-node src/cli.ts --quick",
    "demo": "ts-node src/demo.ts",
    "preview": "ts-node src/preview.ts",
    "debug:patterns": "ts-node src/debug-patterns.ts",
    "setup": "powershell -ExecutionPolicy Bypass -File setup-credentials.ps1",
    "test:config": "ts-node test-credentials.ts",
    "clean": "rimraf dist coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:check": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,md,yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,md,yml,yaml}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --testPathPatterns=unit",
    "test:integration": "jest --testPathPatterns=integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky",
    "prepublishOnly": "npm run build:clean && npm run test && npm run lint:check && npm run format:check",
    "postversion": "git push && git push --tags",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/email-automation-tool.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/email-automation-tool/issues"
  },
  "homepage": "https://github.com/yourusername/email-automation-tool#readme",
  "keywords": [
    "playwright",
    "automation",
    "outlook",
    "gmail",
    "email",
    "scraping",
    "pipeline",
    "portal",
    "search",
    "extraction",
    "data-extraction",
    "rpa",
    "bot",
    "plugin",
    "extensible",
    "typescript"
  ],
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "playwright": "^1.58.2",
    "tesseract.js": "^5.1.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@jest/globals": "^30.2.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
