# Outlook Configuration
OUTLOOK_URL=https://outlook.office.com/mail/
OUTLOOK_EMAIL=your-email@company.com
OUTLOOK_PASSWORD=your-password

# Portal Configuration
PORTAL_URL=https://example-portal.com
PORTAL_USERNAME=your-portal-username
PORTAL_PASSWORD=your-portal-password

# Search Configuration
SEARCH_INPUT_SELECTOR=#searchInput
SEARCH_BUTTON_SELECTOR=#searchBtn
RESULTS_SELECTOR=.search-results

# Automation Settings
HEADLESS=false
SLOW_MO=100
MAX_EMAILS_TO_PROCESS=10
PROCESSED_FOLDER_NAME=Processed

# Logging
LOG_LEVEL=info
